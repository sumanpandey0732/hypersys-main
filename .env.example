# ---------------------------------------------------------------------------
# SERVER-SIDE SECRETS — never exposed to the browser
# ---------------------------------------------------------------------------
# These are read ONLY by the /api proxy (Firebase Functions, Vercel functions,
# or the Vite dev proxy). They must NOT use the VITE_ prefix, because Vite
# inlines any referenced VITE_* var into the client bundle. Keep them unprefixed
# so they stay server-only.
#
# Local dev: put them in .env (loaded by the Vite dev proxy via loadEnv).
# Production (Firebase): firebase functions:secrets:set NVIDIA_API_KEY  (etc.)
# Production (Vercel):    vercel env add NVIDIA_API_KEY                 (etc.)
NVIDIA_API_KEY="your-nvidia-nim-key"
MISTRAL_API_KEY="your-mistral-key"
SERPAPI_API_KEY="your-serpapi-key"
OPENAI_API_KEY="your-openai-key"
GEMINI_API_KEY="your-gemini-key"
XAI_API_KEY="your-xai-key"

# Restrict the /api proxy to your own site(s) so the app key can't be driven
# from other origins. Comma-separated list of allowed origins. Leave unset to
# allow any origin (development default).
# ALLOWED_ORIGINS="https://your-app.web.app,https://your-app.firebaseapp.com"

# ---------------------------------------------------------------------------
# Firebase web config — safe to expose (public web config, not a secret)
# ---------------------------------------------------------------------------
VITE_FIREBASE_API_KEY="your-firebase-web-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_DATABASE_URL="https://your-project-default-rtdb.firebaseio.com"
VITE_FIREBASE_PROJECT_ID="your-project"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="000000000000"
VITE_FIREBASE_APP_ID="1:000000000000:web:xxxxxxxxxxxx"

# NOTE: Users may optionally bring their OWN NVIDIA key via the in-app Settings
# dialog; that key is stored in their browser's localStorage and sent per-
# request. It is never committed here.
